rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /tts-cache/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
